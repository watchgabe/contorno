      <div class="type-label">4.1 / Primary Typeface — Display &amp; Headers</div>
      <div class="type-name">Gabarito — Medium (500)</div>
      <div class="type-specimen-primary">Where creation<br><span style="color:var(--terracotta);">meets</span><br>connection.</div>
