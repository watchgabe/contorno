  <!-- Color Hierarchy Wheel -->
  <div class="wheel-section fi">
    <div class="wheel-left">
      <div class="wheel-eyebrow">3.1 / Color Hierarchy</div>
      <h3 class="wheel-title">Color Hierarchy</h3>
      <p class="wheel-body">A color hierarchy has been implemented, ranging from Terracotta as the dominant expression through Jungle Green and Faded Ocean, with Warm Cream used primarily for background and breathing space. Avoid using tints not specified in this system.</p>
