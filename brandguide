<!-- ═══ BRAND STORY ═══ -->
<section id="brand-story">
  <div class="section-header">
    <div class="section-number">1.0</div>
    <div class="section-title-block">
      <div class="section-eyebrow">The Brand</div>
      <h2 class="section-title">Brand Story</h2>
    </div>
    <div class="doc-info">Contorno Brand Guidelines<br>Section 1.0: Brand Story</div>
  </div>
  <div class="brand-story-grid fi">
    <div class="brand-story-left">
      <h3 class="brand-mission">A space where <em>art, architecture,</em> and natural beauty converge.</h3>
      <p class="brand-body">Contorno is not a hotel with an art program. Not a real estate play dressed up in aesthetics. It's what happens when an architect falls in love with a place and decides to share it — honestly, without apology, and with real intention.</p>
      <blockquote class="brand-promise">"Where creation meets connection. A space designed for makers, not tourists."</blockquote>
      <p class="brand-body">Set on La Punta in Puerto Escondido, Oaxaca — where the Pacific crashes into jungle and polished concrete — Contorno brings the world's creative minds to one of Mexico's last unspoiled coastal paradises.</p>
    </div>
    <div class="brand-story-right">
      <div class="keywords-grid">
        <div class="keyword-group"><h4>Character</h4><p>Understated<br>Authentic<br>Elegant<br>Structured</p></div>
        <div class="keyword-group"><h4>Feeling</h4><p>Contemporary<br>Visionary<br>Empowering<br>Inspiring</p></div>
        <div class="keyword-group"><h4>Function</h4><p>Luxe<br>Ordered<br>Transformative<br>Intentional</p></div>
        <div class="keyword-group"><h4>Spirit</h4><p>Rebellious<br>Playful<br>Culturally curious<br>Unpretentious</p></div>
      </div>
      <div class="if-we-were">
        <h4>If Contorno Were&hellip;</h4>
        <p>Music: Outkast &amp; David Bowie<br>Painters: Michelangelo &amp; Matisse<br>Writer: Oscar Wilde<br>Directors: Kubrick · Wes Anderson<br>Aesthetic: Matisse meets Barragán</p>
        <div class="deco-shape"></div>
      </div>
    </div>
  </div>
</section>

<!-- ═══ VOICE ═══ -->
<section id="voice">
  <div class="section-header">
    <div class="section-number">2.0</div>
    <div class="section-title-block">
      <div class="section-eyebrow">Brand Voice</div>
      <h2 class="section-title">Voice &amp; Tone</h2>
    </div>
    <div class="doc-info">Contorno Brand Guidelines<br>Section 2.0: Voice &amp; Tone</div>
  </div>
  <div class="voice-grid fi">
    <div class="voice-card"><div class="accent-bar"></div><h3>Playfully sophisticated</h3><p>Like finding a Matisse sketch in a beach shack. We don't take ourselves too seriously, but we take the work seriously.</p></div>
    <div class="voice-card"><div class="accent-bar" style="background:var(--jungle)"></div><h3>Romantically rebellious</h3><p>Channeling Bowie, Byron, and Wes Anderson. We break rules beautifully. We never do the expected thing.</p></div>
    <div class="voice-card"><div class="accent-bar" style="background:var(--ocean)"></div><h3>Culturally curious</h3><p>Celebrating Puerto's spirit authentically. Learning from the local art scene rather than importing over it.</p></div>
    <div class="voice-card"><div class="accent-bar" style="background:var(--charcoal)"></div><h3>Unpretentious luxury</h3><p>Polished concrete and jungle palms, not marble and gold. We earn sophistication through taste, not price tags.</p></div>
  </div>
  <div class="tone-examples fi">
    <h3>Voice in Practice</h3>
    <div class="tone-quote-grid">
      <div class="tone-quote"><p>"Some people collect art. We collect artists."</p><div class="quote-mark">&ldquo;</div></div>
      <div class="tone-quote"><p>"Most residencies give you a desk. We give you a month, meals from Boca, and views that make you forget your phone exists."</p><div class="quote-mark">&ldquo;</div></div>
      <div class="tone-quote"><p>"We're not a hotel with an art program. We're an art program with exceptional rooms."</p><div class="quote-mark">&ldquo;</div></div>
      <div class="tone-quote"><p>"This isn't an Airbnb. This is what happens when an architect falls in love with a place and decides to share it."</p><div class="quote-mark">&ldquo;</div></div>
    </div>
  </div>
</section>

<!-- ═══ COLOR ═══ -->
<section id="colors" style="background:var(--charcoal); padding-top:120px; padding-bottom:80px;">
  <div class="section-header" style="border-top-color:rgba(245,240,232,0.1);">
    <div class="section-number section-number-light">3.0</div>
    <div class="section-title-block">
