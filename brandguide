<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Contorno — Brand Guidelines 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=DM+Sans:wght@300;400;500;700&family=Gabarito:wght@400;500;600;700;900&display=swap" rel="stylesheet">
<style>
:root {
  --terracotta: #C0583A;
  --terracotta-light: #D4795E;
  --terracotta-muted: #E8A48A;
  --jungle: #2D5A3D;
  --jungle-light: #4A7A5A;
  --ocean: #7BA4B8;
  --ocean-light: #A8C4D4;
  --offwhite: #F5F0E8;
  --cream: #EDE6D6;
  --charcoal: #2A2A2A;
  --charcoal-mid: #4A4A4A;
  --charcoal-light: #888;
  --white: #FFFFFF;
}
* { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; }
body {
  background:var(--offwhite);
  color:var(--charcoal);
  font-family:'DM Sans',sans-serif;
  font-weight:300;
  overflow-x:hidden;
}

/* ── NAV ── */
nav {
  position:fixed; top:0; left:0; right:0; z-index:100;
  display:flex; justify-content:space-between; align-items:center;
  padding:20px 48px;
  background:rgba(245,240,232,0.92);
  backdrop-filter:blur(12px);
  border-bottom:1px solid rgba(42,42,42,0.08);
}
.nav-brand {
  font-family:'Gabarito',sans-serif; font-weight:500;
  font-size:16px; letter-spacing:0.12em; text-transform:uppercase;
}
.nav-links { display:flex; gap:36px; list-style:none; }
.nav-links a {
  font-size:11px; letter-spacing:0.14em; text-transform:uppercase;
  color:var(--charcoal-mid); text-decoration:none; transition:color .2s;
}
.nav-links a:hover { color:var(--terracotta); }
.nav-meta { font-size:10px; letter-spacing:0.1em; text-transform:uppercase; color:var(--charcoal-light); }

section { min-height:100vh; position:relative; }

/* ── COVER ── */
#cover {
  background:var(--offwhite);
  display:grid; grid-template-columns:1fr 1fr;
  min-height:100vh; overflow:hidden;
}
.cover-left {
  display:flex; flex-direction:column; justify-content:center;
  padding:140px 64px 80px;
  position:relative; z-index:2; gap:48px;
}
.cover-section-label {
  font-size:10px; letter-spacing:0.2em; text-transform:uppercase;
  color:var(--terracotta); margin-bottom:48px;
}
.cover-title {
  font-family:'Gabarito',sans-serif; font-weight:500;
  font-size:clamp(64px,7vw,108px); line-height:0.92;
  color:var(--charcoal); letter-spacing:-0.02em; margin-bottom:48px;
}
.cover-title em { font-style:normal; color:var(--terracotta); font-weight:500; }
.cover-toc {
  display:grid; grid-template-columns:1fr 1fr; gap:0 32px;
  border-top:1px solid rgba(42,42,42,0.1);
}
.toc-row {
  display:flex; justify-content:space-between;
  padding:10px 0; border-bottom:1px solid rgba(42,42,42,0.08);
  font-size:11px; letter-spacing:0.1em; text-transform:uppercase;
  color:var(--charcoal-light);
}
.toc-row span:last-child { color:var(--charcoal-mid); }
.cover-right { position:relative; overflow:hidden; }
.cover-right img {
  width:100%; height:100%; object-fit:cover; object-position:center;
}
.cover-stamp {
  position:absolute; bottom:32px; right:32px;
  font-size:10px; letter-spacing:0.15em; text-transform:uppercase;
  color:rgba(255,255,255,0.65); text-align:right; line-height:2;
}

/* ── SECTION HEADER (V1 style) ── */
.section-header {
  display:flex; justify-content:space-between; align-items:flex-start;
  padding:48px 64px 0;
  border-top:1px solid rgba(42,42,42,0.15);
}
.section-number {
  font-family:'Cormorant Garamond',serif; font-weight:300;
  font-size:72px; color:var(--terracotta); opacity:0.3; line-height:1;
}
.section-title-block { flex:1; padding-left:48px; }
.section-eyebrow {
  font-size:10px; letter-spacing:0.2em; text-transform:uppercase;
  color:var(--charcoal-light); margin-bottom:12px;
}
.section-title {
  font-family:'Gabarito',sans-serif; font-weight:500;
  font-size:44px; letter-spacing:-0.01em; color:var(--charcoal); line-height:1.1;
}
.section-title-light { color:var(--offwhite); }
.section-number-light { color:var(--terracotta); }
.section-eyebrow-light { color:rgba(245,240,232,0.4); }
.doc-info {
  text-align:right; font-size:10px; letter-spacing:0.1em;
  color:var(--charcoal-light); line-height:2;
}
.doc-info-light { color:rgba(245,240,232,0.3); }

/* ── BRAND STORY ── */
#brand-story { background:var(--offwhite); padding-top:120px; }
.brand-story-grid {
  display:grid; grid-template-columns:1fr 1fr; gap:0; padding:64px; padding-top:80px;
}
.brand-story-left { padding-right:80px; border-right:1px solid rgba(42,42,42,0.1); }
.brand-mission {
  font-family:'Gabarito',sans-serif; font-weight:500;
  font-size:clamp(24px,2.5vw,36px); line-height:1.35; color:var(--charcoal); margin-bottom:48px;
}
.brand-mission em { font-style:normal; color:var(--terracotta); font-weight:600; }
.brand-body { font-size:14px; line-height:1.9; color:var(--charcoal-mid); margin-bottom:32px; }
.brand-promise {
  display:block; border-left:3px solid var(--terracotta); padding-left:24px;
  font-family:'Cormorant Garamond',serif; font-style:italic;
  font-size:20px; color:var(--charcoal); line-height:1.6; margin:40px 0;
}
.brand-story-right { padding-left:80px; display:flex; flex-direction:column; justify-content:space-between; }
.keywords-grid { display:grid; grid-template-columns:1fr 1fr; gap:32px; margin-bottom:48px; }
.keyword-group h4 {
  font-size:10px; letter-spacing:0.2em; text-transform:uppercase; color:var(--terracotta); margin-bottom:16px;
}
.keyword-group p { font-family:'Cormorant Garamond',serif; font-size:18px; color:var(--charcoal); line-height:1.8; font-weight:300; }
.if-we-were { background:var(--charcoal); padding:40px; position:relative; overflow:hidden; }
.if-we-were h4 { font-size:10px; letter-spacing:0.2em; text-transform:uppercase; color:var(--terracotta-muted); margin-bottom:24px; }
.if-we-were p { font-family:'Cormorant Garamond',serif; font-size:16px; color:var(--offwhite); line-height:2; font-weight:300; }
.if-we-were .deco-shape {
  position:absolute; bottom:-30px; right:-30px; width:120px; height:120px;
  border-radius:50%; background:var(--terracotta); opacity:0.15;
}

/* ── VOICE ── */
#voice { background:var(--cream); padding-top:120px; padding-bottom:80px; }
.voice-grid {
  display:grid; grid-template-columns:repeat(4,1fr); gap:1px;
  background:rgba(42,42,42,0.1); margin:64px; margin-top:80px;
}
.voice-card { background:var(--cream); padding:48px 40px; transition:background .3s; }
.voice-card:hover { background:var(--offwhite); }
.voice-card h3 {
  font-family:'Gabarito',sans-serif; font-size:22px; font-weight:500;
  color:var(--charcoal); margin-bottom:16px; line-height:1.2;
}
.voice-card p { font-size:12px; line-height:1.8; color:var(--charcoal-mid); }
.voice-card .accent-bar { width:32px; height:2px; background:var(--terracotta); margin-bottom:24px; }
.tone-examples { padding:0 64px 64px; }
.tone-examples h3 {
  font-size:10px; letter-spacing:0.2em; text-transform:uppercase; color:var(--charcoal-light); margin-bottom:40px;
}
.tone-quote-grid { display:grid; grid-template-columns:1fr 1fr; gap:24px; }
.tone-quote {
  padding:32px; border:1px solid rgba(42,42,42,0.1); position:relative;
  background:var(--white);
}
.tone-quote:nth-child(even) { background:transparent; }
.tone-quote p {
  font-family:'Cormorant Garamond',serif; font-size:20px; font-weight:300;
  font-style:italic; color:var(--charcoal); line-height:1.5;
}
.tone-quote .quote-mark {
  position:absolute; top:16px; right:20px;
  font-family:'Cormorant Garamond',serif; font-size:72px;
  color:var(--terracotta); opacity:0.15; line-height:1;
}

/* ── COLOR ── */
#colors { background:var(--charcoal); padding-top:120px; padding-bottom:80px; }
#colors .section-header { border-top-color:rgba(245,240,232,0.1); }
.color-intro { padding:48px 64px; max-width:700px; font-size:14px; line-height:1.9; color:rgba(245,240,232,0.6); }
.color-palette-main { padding:0 64px 0; display:flex; gap:0; }
.color-block { flex:1; cursor:pointer; transition:flex .4s ease; }
.color-block:hover { flex:1.5; }
.color-swatch { height:280px; position:relative; display:flex; align-items:flex-end; padding:24px; transition:height .3s; }
.color-block:hover .color-swatch { height:320px; }
.color-name-badge {
  background:rgba(0,0,0,0.3); backdrop-filter:blur(8px);
  padding:8px 16px; font-family:'Cormorant Garamond',serif;
  font-size:18px; color:white; font-weight:300;
  opacity:0; transition:opacity .3s;
}
.color-block:hover .color-name-badge { opacity:1; }
.color-info { padding:24px; border-bottom:1px solid rgba(245,240,232,0.06); }
.color-info h4 { font-family:'Cormorant Garamond',serif; font-size:22px; font-weight:300; color:var(--offwhite); margin-bottom:12px; }
.color-info .color-role { font-size:10px; letter-spacing:0.15em; text-transform:uppercase; color:rgba(245,240,232,0.4); margin-bottom:16px; }
.color-values { display:flex; flex-direction:column; gap:4px; }
.color-value { display:flex; justify-content:space-between; font-size:11px; color:rgba(245,240,232,0.5); }
.color-value span:first-child { font-size:9px; text-transform:uppercase; letter-spacing:0.1em; color:rgba(245,240,232,0.3); }

/* Color wheel section */
.wheel-section {
  display:grid; grid-template-columns:1fr 1fr; gap:0;
  padding:64px; padding-top:48px; border-top:1px solid rgba(245,240,232,0.08); margin-top:48px;
}
.wheel-left { padding-right:64px; border-right:1px solid rgba(245,240,232,0.08); }
.wheel-eyebrow {
  font-size:10px; letter-spacing:0.2em; text-transform:uppercase;
  color:rgba(245,240,232,0.3); margin-bottom:16px;
}
.wheel-title {
  font-family:'Gabarito',sans-serif; font-weight:500;
  font-size:32px; color:var(--offwhite); margin-bottom:24px;
}
.wheel-body { font-size:13px; line-height:2; color:rgba(245,240,232,0.5); margin-bottom:40px; }
.wheel-legend { }
.wl-item {
  display:flex; align-items:center; gap:14px; padding:12px 0;
  border-bottom:1px solid rgba(245,240,232,0.06);
  font-size:12px; color:rgba(245,240,232,0.5);
}
.wl-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; }
.wl-pct { margin-left:auto; font-size:10px; letter-spacing:0.1em; color:rgba(245,240,232,0.25); }
.wheel-right { padding-left:64px; display:flex; align-items:center; justify-content:center; }

/* ── TYPOGRAPHY ── */
#typography { background:var(--offwhite); padding-top:120px; padding-bottom:80px; }
.type-showcase { padding:64px; padding-top:80px; }
.type-primary {
  background:var(--charcoal); padding:80px 64px; margin-bottom:2px;
  position:relative; overflow:hidden;
}
.type-label { font-size:10px; letter-spacing:0.2em; text-transform:uppercase; color:rgba(245,240,232,0.3); margin-bottom:40px; }
.type-name { font-size:11px; letter-spacing:0.15em; text-transform:uppercase; color:var(--terracotta); margin-bottom:16px; }
.type-specimen-primary {
  font-family:'Gabarito',sans-serif; font-weight:500;
  font-size:clamp(48px,7vw,96px); color:var(--offwhite); line-height:1; letter-spacing:-0.02em;
}
.type-specimen-primary span { color:var(--terracotta-muted); }
.type-desc { font-size:12px; line-height:1.8; color:rgba(245,240,232,0.4); max-width:420px; margin-top:40px; }
.type-deco-char {
  position:absolute; right:64px; bottom:-20px;
  font-family:'Cormorant Garamond',serif; font-size:320px; color:white;
  opacity:0.04; line-height:1; font-weight:300; user-select:none;
}
.type-secondary { background:var(--white); padding:64px; margin-bottom:48px; }
.type-specimen-secondary {
  font-family:'DM Sans',sans-serif; font-weight:300;
  font-size:clamp(36px,5vw,64px); color:var(--charcoal); line-height:1.1; letter-spacing:-0.01em; margin:24px 0;
}
.type-hierarchy-table {
  display:grid; grid-template-columns:1fr 2fr 1fr 1fr 1fr; gap:0;
  border:1px solid rgba(42,42,42,0.1); margin:0 64px;
}
.th-cell { padding:20px 24px; border-bottom:1px solid rgba(42,42,42,0.08); border-right:1px solid rgba(42,42,42,0.08); font-size:12px; color:var(--charcoal-mid); }
.th-header { font-size:10px; letter-spacing:0.15em; text-transform:uppercase; color:var(--charcoal-light); background:rgba(42,42,42,0.03); }

/* ── IMAGE DIRECTION ── */
#imagery { background:var(--offwhite); padding-top:120px; }

.img-intro-grid {
  display:grid; grid-template-columns:1fr 1fr; gap:64px;
  padding:64px; padding-top:80px;
}
.img-intro-left p { font-size:14px; line-height:1.9; color:var(--charcoal-mid); }
.img-do-dont { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
.do-block { padding:24px; background:rgba(45,90,61,0.08); border-top:2px solid var(--jungle); }
.dont-block { padding:24px; background:rgba(192,88,58,0.06); border-top:2px solid var(--terracotta); }
.do-block h4 { font-size:10px; letter-spacing:0.2em; text-transform:uppercase; color:var(--jungle); margin-bottom:14px; }
.dont-block h4 { font-size:10px; letter-spacing:0.2em; text-transform:uppercase; color:var(--terracotta); margin-bottom:14px; }
.do-block ul, .dont-block ul { list-style:none; font-size:12px; line-height:2.1; color:var(--charcoal-mid); }
.do-block ul li::before { content:'+  '; color:var(--jungle); }
.dont-block ul li::before { content:'×  '; color:var(--terracotta); }

/* Treatment segments */
.treatment-seg {
  display:grid; grid-template-columns:1fr 2fr; border-top:1px solid rgba(42,42,42,0.1);
}
.ts-left {
  padding:64px; border-right:1px solid rgba(42,42,42,0.1);
  display:flex; flex-direction:column; justify-content:space-between;
}
.ts-num {
  font-family:'Cormorant Garamond',serif; font-weight:300;
  font-size:80px; color:var(--terracotta); opacity:0.2; line-height:1; margin-bottom:16px;
}
.ts-title { font-family:'Gabarito',sans-serif; font-weight:500; font-size:28px; color:var(--charcoal); margin-bottom:20px; }
.ts-desc { font-size:13px; line-height:1.9; color:var(--charcoal-mid); }
.ts-right { padding:48px; }
.mosaic { display:grid; gap:8px; }
.mi {
  background:var(--cream); border:1px solid rgba(42,42,42,0.08);
  display:flex; align-items:flex-end; justify-content:flex-start;
  padding:10px; font-size:8px; letter-spacing:0.12em; text-transform:uppercase;
  color:var(--charcoal-light); position:relative; overflow:hidden;
}

/* Sketch full panel */
.sketch-full {
  display:grid; grid-template-columns:1fr 1fr; min-height:90vh;
  border-top:1px solid rgba(42,42,42,0.1);
}
.sketch-panel-left {
  padding:72px 64px; border-right:1px solid rgba(42,42,42,0.1);
  display:flex; flex-direction:column; justify-content:space-between;
}
.sketch-panel-left h2 {
  font-family:'Gabarito',sans-serif; font-weight:500;
  font-size:clamp(36px,4.5vw,58px); line-height:1.05; letter-spacing:-0.01em;
}
.sketch-panel-left h2 em { font-style:italic; color:var(--terracotta); }
.sketch-body { font-size:13px; line-height:2; color:var(--charcoal-mid); max-width:380px; margin-bottom:32px; }
.sketch-rule {
  padding:14px 0; border-bottom:1px solid rgba(42,42,42,0.1);
  font-size:12px; line-height:1.8; color:var(--charcoal-mid);
  display:flex; gap:16px;
}
.sketch-rule::before { content:'—'; color:var(--terracotta); flex-shrink:0; }
.sketch-panel-right {
  background:var(--charcoal); position:relative; overflow:hidden;
}

/* Matisse treatment dark panel */
.matisse-seg {
  display:grid; grid-template-columns:1fr 2fr; border-top:1px solid rgba(245,240,232,0.08);
  background:var(--charcoal);
}
.ms-left {
  padding:64px; border-right:1px solid rgba(245,240,232,0.08);
  display:flex; flex-direction:column; justify-content:space-between;
}
.ms-num { font-family:'Cormorant Garamond',serif; font-size:80px; font-weight:300; color:var(--terracotta); opacity:0.25; line-height:1; margin-bottom:16px; }
.ms-title { font-family:'Gabarito',sans-serif; font-weight:500; font-size:28px; color:var(--offwhite); margin-bottom:20px; }
.ms-desc { font-size:13px; line-height:1.9; color:rgba(245,240,232,0.5); }
.ms-right { padding:48px; }

/* ── DIGITAL MOCKUPS ── */
#digital { background:var(--cream); padding-top:120px; padding-bottom:80px; }
.mockup-inner { padding:64px; padding-top:80px; }
.mockup-intro { font-size:14px; line-height:1.9; color:var(--charcoal-mid); max-width:560px; margin-bottom:72px; }
.phones-row { display:flex; gap:32px; align-items:flex-end; margin-bottom:80px; }
.phone-wrap { flex-shrink:0; width:200px; filter:drop-shadow(0 24px 48px rgba(42,42,42,0.22)); }
.phone-shell { background:var(--charcoal); border-radius:36px; padding:10px; border:2px solid #3a3a3a; }
.phone-notch { width:72px; height:6px; background:#111; border-radius:4px; margin:0 auto 8px; }
.phone-screen { border-radius:26px; overflow:hidden; aspect-ratio:9/19.5; position:relative; }
.ps-logo {
  position:absolute; top:16px; left:0; right:0; text-align:center;
  font-family:'Gabarito',sans-serif; font-weight:500;
  font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:white; opacity:0.9;
}
.ps-overlay {
  position:absolute; inset:0; display:flex; flex-direction:column;
  justify-content:flex-end; padding:20px;
  background:linear-gradient(to top, rgba(42,42,42,0.88) 0%, transparent 55%);
}
.ps-text { font-family:'Cormorant Garamond',serif; font-weight:300; font-size:17px; color:white; line-height:1.2; margin-bottom:12px; }
.ps-cta {
  background:rgba(42,42,42,0.7); border:1px solid rgba(255,255,255,0.25);
  font-size:8px; letter-spacing:0.16em; text-transform:uppercase;
  padding:7px 14px; color:white; display:inline-block; text-align:center;
}
.phone-wrap.p2 { transform:translateY(-24px); }
.phone-wrap.p3 { transform:translateY(-12px); }
.desktop-label {
  font-size:10px; letter-spacing:0.2em; text-transform:uppercase;
  color:var(--charcoal-light); margin-bottom:16px;
}
.desktop-wrap { filter:drop-shadow(0 20px 48px rgba(42,42,42,0.18)); }
.desktop-shell { background:#3d3d3d; border-radius:12px 12px 0 0; padding:10px 10px 0; }
.desktop-dots { display:flex; gap:6px; align-items:center; padding-bottom:8px; }
.dd { width:10px; height:10px; border-radius:50%; }
.desktop-screen { border-radius:4px 4px 0 0; overflow:hidden; aspect-ratio:16/9; }
.dsc-inner { width:100%; height:100%; background:var(--offwhite); display:flex; flex-direction:column; }
.dsc-nav {
  height:44px; background:white; border-bottom:1px solid rgba(42,42,42,0.08);
  display:flex; align-items:center; justify-content:space-between; padding:0 28px; flex-shrink:0;
}
.dsc-nav-brand { font-family:'Gabarito',sans-serif; font-weight:500; font-size:14px; letter-spacing:0.14em; text-transform:uppercase; }
.dsc-nav-links { display:flex; gap:18px; }
.dsc-nav-link { font-size:8px; letter-spacing:0.12em; text-transform:uppercase; color:var(--charcoal-light); }
.dsc-hero { flex:1; display:flex; }
.dsc-hero-img { width:48%; background:linear-gradient(135deg,#8a7a6a,#4a3a2a); position:relative; overflow:hidden; }
.dsc-hero-img-inner { position:absolute; inset:0; background:linear-gradient(160deg,#7a6858 0%,#3a2a1a 100%); }
.dsc-hero-content { flex:1; padding:28px; display:flex; flex-direction:column; justify-content:center; }
.dsc-eyebrow { font-size:7px; letter-spacing:0.2em; text-transform:uppercase; color:var(--terracotta); margin-bottom:8px; }
.dsc-h1 { font-family:'Gabarito',sans-serif; font-weight:500; font-size:22px; line-height:1.15; color:var(--charcoal); margin-bottom:10px; }
.dsc-h1 em { font-style:italic; color:var(--terracotta); }
.dsc-p { font-size:8px; line-height:1.9; color:var(--charcoal-mid); margin-bottom:14px; }
.dsc-cta { background:var(--charcoal); color:white; font-size:7px; letter-spacing:0.15em; text-transform:uppercase; padding:7px 14px; display:inline-block; }
.desktop-stand { height:16px; background:#2a2a2a; width:38%; margin:0 auto; border-radius:0 0 4px 4px; }
.desktop-base { height:5px; background:#1a1a1a; width:52%; margin:0 auto; border-radius:3px; }

/* ── SUB-BRAND PANELS ── */
.sb-panel {
