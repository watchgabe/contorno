---
import BaseLayout from '../layouts/BaseLayout.astro';

const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
const img = (file: string) => `${BASE}/Edited copy/${file}`;
---

<BaseLayout
  title="Stay — Contorno"
  description="Bookings coming soon. Join the waitlist."
>
  <section class="coming">
    <div class="coming-text">
      <p class="coming-eyebrow">Bookings</p>
      <h1 class="coming-heading">Coming soon.</h1>
      <p class="coming-body">
        Contorno isn't open for stays just yet. The space is still being built — pour by pour, room by room.
      </p>
      <p class="coming-body">
        Leave your email and we'll write once when the doors open. No newsletter, no marketing — just a note from us when there's something to book.
      </p>

      <form id="waitlist-form" class="waitlist-form" novalidate>
        <input type="email" name="email" placeholder="you@email.com" autocomplete="email" required />
        <button type="submit" class="btn btn-dark">Join the waitlist <span class="arr">→</span></button>
      </form>

      <p id="waitlist-msg" class="coming-fine" role="status" aria-live="polite"></p>
      <p class="coming-fine">We'll only email you when there's news worth sending.</p>
    </div>

    <div class="coming-image">
      <img src={img('Nick Paxifico.jpg')} alt="Puerto Escondido coastline" fetchpriority="high" decoding="async" />
      <span class="label">Puerto Escondido · Oaxaca</span>
      <div class="coords">
        15.8442° N<br />
        97.0418° W
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .coming {
    min-height: calc(100vh - var(--nav-h));
    padding: calc(var(--nav-h) + 60px) 40px 60px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    align-items: stretch;
  }

  .coming-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 40px 60px 40px 0;
    max-width: 620px;
  }
  .coming-eyebrow {
    font-family: var(--sans);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--terra);
    margin-bottom: 26px;
  }
  .coming-heading {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(40px, 5.4vw, 72px);
    line-height: 1.08;
    letter-spacing: -0.005em;
    color: var(--ink);
    margin-bottom: 28px;
  }
  .coming-body {
    font-family: var(--sans);
    font-weight: 300;
    font-size: 16px;
    line-height: 1.8;
    color: var(--ink-soft);
    max-width: 520px;
    margin-bottom: 38px;
  }
  .coming-body + .coming-body { margin-top: -22px; }

  /* Inline waitlist form */
  .waitlist-form {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    max-width: 480px;
    margin-bottom: 18px;
  }
  .waitlist-form input[type="email"] {
    flex: 1;
    min-width: 240px;
    padding: 14px 16px;
    font-family: var(--sans);
    font-weight: 300;
    font-size: 14px;
    background: var(--offwhite);
    border: 1px solid var(--hairline);
    border-radius: 2px;
    color: var(--ink);
    outline: none;
    transition: border-color 0.2s;
  }
  .waitlist-form input[type="email"]:focus { border-color: var(--terra); }
  .waitlist-form input[type="email"]::placeholder { color: var(--mid); }

  .coming-fine {
    font-family: var(--sans);
    font-weight: 300;
    font-size: 12px;
    color: var(--mid);
    line-height: 1.6;
    max-width: 480px;
  }
  #waitlist-msg { margin-bottom: 10px; min-height: 1em; }
  #waitlist-msg.is-success { color: var(--ink); }
  #waitlist-msg.is-error { color: var(--terra); }

  .coming-image {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    background: #1a1a1a;
    min-height: 520px;
  }
  .coming-image img {
    width: 100%; height: 100%;
    object-fit: cover;
    position: absolute; inset: 0;
  }
  .coming-image .label {
    position: absolute;
    top: 26px; right: 26px;
    font-family: var(--sans);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.78);
  }
  .coming-image .coords {
    position: absolute;
    bottom: 26px; left: 26px;
    font-family: var(--sans);
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.78);
    line-height: 1.8;
  }

  @media (max-width: 960px) {
    .coming { grid-template-columns: 1fr; padding: calc(var(--nav-h) + 40px) 24px 40px; gap: 30px; }
    .coming-text { padding: 0; }
    .coming-image { min-height: 360px; }
  }
</style>

<script is:inline>
  (function () {
    var form = document.getElementById('waitlist-form');
    if (!form) return;
    var msg = document.getElementById('waitlist-msg');
    var btn = form.querySelector('button[type="submit"]');
    var input = form.querySelector('input[type="email"]');
    var originalLabel = btn.innerHTML;

    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      var email = (input.value || '').trim();
      if (!email) return;

      btn.disabled = true;
      btn.textContent = 'Sending…';
      msg.textContent = '';
      msg.classList.remove('is-error', 'is-success');

      try {
        var debug = new URLSearchParams(location.search).get('debug') === '1';
        var res = await fetch('/api/waitlist' + (debug ? '?debug=1' : ''), {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email })
        });
        var data = await res.json().catch(function () { return {}; });
        if (res.ok && data.ok) {
          form.reset();
          input.disabled = true;
          msg.textContent = "You're on the list. We'll write when there's something to book.";
          msg.classList.add('is-success');
          btn.textContent = 'Joined ✓';
        } else {
          msg.textContent = data.error || 'Something went wrong. Please try again.';
          msg.classList.add('is-error');
          btn.innerHTML = originalLabel;
          btn.disabled = false;
        }
      } catch (err) {
        msg.textContent = 'Network error. Please try again.';
        msg.classList.add('is-error');
        btn.innerHTML = originalLabel;
        btn.disabled = false;
      }
    });
  })();
</script>
