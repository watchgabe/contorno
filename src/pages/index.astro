<BaseLayout>
  <div class="hero-wrapper">
    <section class="hero">
      <img class="hero-img" src={img('L3 Construction.jpg')} alt="Contorno — building in Puerto Escondido" />
      <div class="hero-overlay"></div>

      <div class="hero-coords">
        15.8442° N<br />
        97.0418° W
      </div>

      <div class="hero-label">Puerto Escondido · 2026</div>

      <div class="hero-content">
        <h1 class="hero-title">contorno</h1>
        <p class="hero-desc">the process of building — documented from the ground up.</p>
      </div>
    </section>
  </div>

  <section class="intro">
    <p class="intro-eyebrow">the project</p>
    <h2 class="intro-headline">
      not a finished thing —<br />
      a thing <em>becoming</em>.
    </h2>
    <div class="intro-body">
      <p>
        Contorno is a record of construction in progress. It documents the way a building
        takes shape — the decisions made on site, the materials handled by hand, the moments
        between the plans and the pour.
      </p>
      <p>
        Based in Puerto Escondido, Oaxaca, the project follows Nick and Ricardo
        through the arc of building: from raw land to finished structure,
        told in photographs and in real time.
      </p>
    </div>
  </section>

  <div class="divider"></div>

  <section id="work">
    <div class="section-header">
      <h2 class="section-title">the build</h2>
      <span class="section-tag">Puerto Escondido · 2026</span>
    </div>

    <div class="gallery">
      {galleryImages.map((file) => (
        <figure><img src={img(file)} alt="" loading="lazy" /></figure>
      ))}
    </div>
  </section>

  <div class="divider"></div>

  <section class="feature">
    <img src={img('Nick & Ricardo Posing.jpg')} alt="Nick and Ricardo on site" />
    <div class="feature-overlay"></div>
    <div class="feature-caption">
      <span class="feature-caption-label">on site</span>
      <span class="feature-caption-label">Puerto Escondido, Oaxaca</span>
    </div>
  </section>

  <section class="about" id="about">
    <div class="about-image">
      <img src={img('Black & White.jpg')} alt="Contorno — construction detail" />
    </div>
    <div class="about-text">
      <p class="about-eyebrow">the people</p>
      <h2 class="about-headline">
        two people building<br />
        something <em>real</em>.
      </h2>
      <div class="about-body">
        <p>
          Nick and Ricardo are the people behind Contorno — not developers,
          not a firm. Two individuals who decided to build something themselves,
          in a place they love, with their hands.
        </p>
        <p>
          The project lives in Puerto Escondido, Oaxaca. The photographs
          document what happens between the idea and the thing: the concrete
          poured, the steel bent, the decisions made in daylight on a
          half-finished floor.
        </p>
        <p>
          Contorno is the outline of a building taking shape.
        </p>
      </div>
      <div class="about-names">
        <span class="about-name">Nick —</span>
        <span class="about-name">Ricardo —</span>
      </div>
    </div>
  </section>
</BaseLayout>
