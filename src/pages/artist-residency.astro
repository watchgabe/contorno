---
import BaseLayout from '../layouts/BaseLayout.astro';

const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
const img = (file: string) => `${BASE}/Edited copy/${file}`;

const TYPEFORM_URL = 'https://453f8jrwcv1.typeform.com/to/QAik2KWu';
---

<BaseLayout
  title="Artist Residency — Contorno"
  description="A month in Puerto Escondido for artists with a body of work and a point of view."
>
  <div class="hero-wrapper">
    <section class="hero">
      <img class="hero-img" src={img('I like this one.jpg')} alt="Artist residency at Contorno" fetchpriority="high" decoding="async" />
      <div class="hero-overlay"></div>

      <div class="hero-coords">
        15.8442° N<br />
        97.0418° W
      </div>
      <div class="hero-label">Artist Residency</div>

      <div class="hero-content">
        <p class="hero-eyebrow">Artist Residency at Contorno</p>
        <h1 class="hero-title">arc</h1>
        <p class="hero-subhead">A month. A unit. A meal. The Pacific.</p>
      </div>
    </section>
  </div>

  <section class="suite reveal">
    <div class="suite-image">
      <img src={img('I like this one.jpg')} alt="The residency unit at Contorno" loading="lazy" decoding="async" />
      <span class="label">The Residency</span>
    </div>
    <div class="suite-body">
      <h2 class="suite-heading">Three to four artists. One month each.</h2>
      <div class="suite-copy">
        <p>Rent covered, meals handled, a per diem for everything else. You make work. You leave one piece behind that lives at Contorno.</p>
        <p>That's it. That's the program.</p>
      </div>
      <ul class="suite-features">
        <li><span class="name">Private unit</span><span class="desc">A studio at Contorno with views of La Punta.</span><span class="dot"></span></li>
        <li><span class="name">Meals at Boca</span><span class="desc">Breakfast and dinner, on us.</span><span class="dot"></span></li>
        <li><span class="name">Daily per diem</span><span class="desc">Covers everything else while you're here.</span><span class="dot"></span></li>
        <li><span class="name">Studio &amp; grounds</span><span class="desc">Workspace and the full run of the property.</span><span class="dot"></span></li>
        <li><span class="name">Uninterrupted time</span><span class="desc">A full month of focus on the Pacific.</span><span class="dot"></span></li>
      </ul>
    </div>
  </section>

  <div class="divider"></div>

  <div class="section-header reveal">
    <h2 class="section-title">The space</h2>
    <span class="section-tag">Puerto Escondido · La Punta</span>
  </div>

  <section class="space reveal">
    <figure class="s-1"><img src={img('L3 Construction.jpg')} alt="" loading="lazy" decoding="async" /></figure>
    <figure class="s-2"><img src={img('Nick Paxifico.jpg')} alt="" loading="lazy" decoding="async" /></figure>
    <figure class="s-3"><img src={img('Black & White.jpg')} alt="" loading="lazy" decoding="async" /></figure>
    <figure class="s-4"><img src={img('I like this one.jpg')} alt="" loading="lazy" decoding="async" /></figure>
    <figure class="s-5"><img src={img('Ricardo Lines.jpg')} alt="" loading="lazy" decoding="async" /></figure>
  </section>

  <div class="divider"></div>

  <section class="apply reveal" id="apply">
    <div class="apply-head">
      <p class="apply-eyebrow">Apply</p>
      <h2 class="apply-heading">Takes about ten minutes. We read every one.</h2>
    </div>
    <div class="apply-frame">
      <iframe
        src={TYPEFORM_URL}
        title="Contorno Artist Residency Application"
        allow="camera; microphone; autoplay; encrypted-media; fullscreen"
        loading="lazy"
      ></iframe>
    </div>
  </section>

  <section class="faq reveal">
    <div class="faq-head">
      <h2 class="section-title">FAQ</h2>
      <span class="section-tag">questions, answered</span>
    </div>

    <details class="faq-item">
      <summary>Do I need to be represented by a gallery? <span class="faq-toggle">+</span></summary>
      <div class="faq-answer">No.</div>
    </details>
    <details class="faq-item">
      <summary>Do I need a certain follower count? <span class="faq-toggle">+</span></summary>
      <div class="faq-answer">No, but we do look at how you share your work and the audience around it. Not as a gate — one signal among many.</div>
    </details>
    <details class="faq-item">
      <summary>Can I bring a partner? <span class="faq-toggle">+</span></summary>
      <div class="faq-answer">Yes. Note it in the application.</div>
    </details>
    <details class="faq-item">
      <summary>What if I don't know what I'd make for the space yet? <span class="faq-toggle">+</span></summary>
      <div class="faq-answer">That's fine. We want to see how you think, not a finished pitch.</div>
    </details>
    <details class="faq-item">
      <summary>Is there an application fee? <span class="faq-toggle">+</span></summary>
      <div class="faq-answer">No.</div>
    </details>
  </section>
</BaseLayout>

<style>
  /* ─── ARC ─────────────────────────────────────── */
  .hero-title { font-size: clamp(96px, 18vw, 240px); letter-spacing: 0.02em; }

  /* ─── SUITE BLOCK (image left, write-up + features right) ─── */
  .suite {
    padding: 110px 40px 120px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    max-width: 1280px;
    margin: 0 auto;
  }
  .suite-image {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    background: #ddd5c2;
  }
  .suite-image img {
    width: 100%; height: 100%;
    object-fit: cover;
  }
  .suite-image .label {
    position: absolute;
    top: 22px; left: 22px;
    font-family: var(--sans);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.86);
    text-shadow: 0 1px 12px rgba(0,0,0,0.55);
  }

  .suite-body { padding-right: 20px; }
  .suite-heading {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(32px, 3.6vw, 48px);
    line-height: 1.14;
    letter-spacing: -0.005em;
    color: var(--ink);
    margin-bottom: 24px;
  }
  .suite-copy {
    font-family: var(--sans);
    font-weight: 300;
    font-size: 15.5px;
    line-height: 1.75;
    color: var(--ink-soft);
    max-width: 460px;
    margin-bottom: 40px;
  }
  .suite-copy p + p { margin-top: 14px; }

  .suite-features { list-style: none; }
  .suite-features li {
    display: grid;
    grid-template-columns: 160px 1fr 18px;
    gap: 24px;
    align-items: start;
    padding: 18px 0;
    border-top: 1px solid var(--hairline);
  }
  .suite-features li:last-child { border-bottom: 1px solid var(--hairline); }
  .suite-features li .name {
    font-family: var(--sans);
    font-weight: 500;
    font-size: 14.5px;
    color: var(--ink);
    line-height: 1.45;
  }
  .suite-features li .desc {
    font-family: var(--sans);
    font-weight: 300;
    font-size: 13.5px;
    color: var(--ink-soft);
    line-height: 1.55;
  }
  .suite-features li .dot {
    width: 7px; height: 7px;
    border-radius: 100px;
    background: var(--terra);
    margin-top: 8px;
    justify-self: end;
  }

  @media (max-width: 960px) {
    .suite { grid-template-columns: 1fr; padding: 70px 24px 80px; gap: 32px; }
    .suite-body { padding-right: 0; }
    .suite-features li { grid-template-columns: 130px 1fr 12px; gap: 16px; }
  }

  /* ─── SPACE GRID ────────────────────────────────── */
  .space {
    padding: 0 40px 90px;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: 180px;
    gap: 12px;
  }
  .space figure { overflow: hidden; border-radius: 8px; background: #ddd5c2; }
  .space figure img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.7s ease; }
  .space figure:hover img { transform: scale(1.03); }
  .s-1 { grid-column: span 4; grid-row: span 2; }
  .s-2 { grid-column: span 2; grid-row: span 1; }
  .s-3 { grid-column: span 2; grid-row: span 1; }
  .s-4 { grid-column: span 3; grid-row: span 2; }
  .s-5 { grid-column: span 3; grid-row: span 2; }

  .space-caption {
    padding: 0 40px 100px;
    max-width: 640px;
  }
  .space-caption p {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(20px, 2.4vw, 26px);
    line-height: 1.35;
    color: var(--ink);
  }

  /* ─── APPLY (Typeform embed) ────────────────────── */
  .apply {
    padding: 100px 40px 100px;
  }
  .apply-head {
    display: grid;
    grid-template-columns: 0.7fr 1.3fr;
    gap: 40px 90px;
    margin-bottom: 44px;
    align-items: end;
  }
  .apply-eyebrow {
    font-family: var(--sans);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--terra);
  }
  .apply-heading {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(34px, 4.4vw, 54px);
    line-height: 1.12;
    letter-spacing: -0.005em;
    color: var(--ink);
  }
  .apply-frame {
    background: var(--offwhite);
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--hairline);
    min-height: 640px;
  }
  .apply-frame iframe {
    width: 100%; height: 640px; border: 0; display: block;
  }

  /* ─── WAITLIST ──────────────────────────────────── */
  .waitlist {
    margin: 0 var(--frame) var(--frame);
    background: var(--ink);
    color: var(--cream);
    border-radius: 12px;
    padding: 100px 40px 110px;
    text-align: center;
  }
  .waitlist-eyebrow {
    font-family: var(--sans);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--terra);
    margin-bottom: 26px;
  }
  .waitlist-heading {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(36px, 5vw, 60px);
    line-height: 1.15;
    letter-spacing: -0.005em;
    color: var(--cream);
    max-width: 720px;
    margin: 0 auto 18px;
  }
  .waitlist-body {
    font-family: var(--sans);
    font-weight: 300;
    font-size: 15px;
    color: rgba(237,230,214,0.75);
    max-width: 480px;
    margin: 0 auto 32px;
    line-height: 1.7;
  }
  .btn-onink {
    background: var(--cream);
    color: var(--ink);
    border: 1px solid var(--cream);
  }
  .btn-onink:hover { background: #fff; }

  /* ─── FAQ ────────────────────────────────────────── */
  .faq {
    padding: 110px 40px 110px;
    max-width: 1100px;
    margin: 0 auto;
  }
  .faq-head {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 24px; flex-wrap: wrap;
    margin-bottom: 30px;
  }
  details.faq-item {
    border-top: 1px solid var(--hairline);
    padding: 24px 0;
  }
  details.faq-item:last-child { border-bottom: 1px solid var(--hairline); }
  details.faq-item summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 24px;
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(20px, 2vw, 24px);
    line-height: 1.25;
    color: var(--ink);
  }
  details.faq-item summary::-webkit-details-marker { display: none; }
  .faq-toggle {
    font-family: var(--sans);
    font-weight: 300;
    font-size: 22px;
    color: var(--terra);
    transition: transform 0.25s ease;
    line-height: 1;
  }
  details[open] .faq-toggle { transform: rotate(45deg); }
  details.faq-item .faq-answer {
    margin-top: 12px;
    font-family: var(--sans);
    font-weight: 300;
    font-size: 15px;
    line-height: 1.7;
    color: var(--ink-soft);
    max-width: 760px;
  }

  @media (max-width: 960px) {
    .space { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 200px; padding: 0 24px 60px; }
    .s-1, .s-2, .s-3, .s-4, .s-5 { grid-column: span 2; grid-row: span 1; }
    .s-1 { grid-row: span 2; }
    .space-caption { padding: 0 24px 60px; }
    .apply { padding: 70px 24px 70px; }
    .apply-head { grid-template-columns: 1fr; gap: 16px; }
    .waitlist { padding: 70px 24px 80px; margin: 0 10px 10px; }
    .faq { padding: 70px 24px 80px; }
  }
</style>
