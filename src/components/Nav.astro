---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const link = (path: string) => `${base}${path}` || '/';
const path = Astro.url.pathname.replace(/\/$/, '');
const isHome = path === base || path === '' || path === '/';
const isActive = (p: string) => path === `${base}${p}`.replace(/\/$/, '');
---

<nav class="site-nav">
  <div class="nav-left">
    <a href={link('/')} class={isHome ? 'active' : ''}>the project</a>
    <a href={link('/artist-residency')} class={isActive('/artist-residency') ? 'active' : ''}>residency</a>
    <a href={link('/stay')} class={isActive('/stay') ? 'active' : ''}>stay</a>
  </div>
  <a href={link('/')} class="nav-logo">contorno</a>
  <div class="nav-right">
    <a href="https://instagram.com/contornocollective" target="_blank" rel="noopener">instagram</a>
    <a href="mailto:hello@contornocollective.com">contact</a>
  </div>
</nav>
