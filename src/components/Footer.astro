---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const link = (path: string) => `${base}${path}`;
const CONTACT_EMAIL = 'hello@contornocollective.com';
---

<footer>
  <div class="footer-brand">
    <p class="footer-wordmark">contorno</p>
    <p class="footer-tagline">building in Puerto Escondido, Oaxaca — documented in real time.</p>
  </div>

  <div class="footer-col">
    <p class="footer-col-title">location</p>
    <p>Puerto Escondido</p>
    <p>Oaxaca, México</p>
  </div>

  <div class="footer-col">
    <p class="footer-col-title">links</p>
    <a href={link('/artist-residency')}>artist residency</a>
    <a href={link('/#work')}>the build</a>
    <a href={link('/#about')}>about</a>
  </div>

  <div class="footer-col">
    <p class="footer-col-title">contact</p>
    <a href={`mailto:${CONTACT_EMAIL}`} class="footer-email">{CONTACT_EMAIL}</a>
  </div>

  <div class="footer-bottom">
    <p class="footer-giant">contorno</p>
  </div>
</footer>
